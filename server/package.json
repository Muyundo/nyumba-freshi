{
  "name": "nyumba-freshi-server",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "cross-env DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/nyumba_freshi nodemon --watch src --exec node src/index.js",
