  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "better-sqlite3": "^12.6.2",
    "cross-env": "^10.1.0",
    "nodemon": "^2.0.22"
  }
}
