# Server Configuration
PORT=4000
HOST=0.0.0.0

# JWT settings
# Use a strong random secret in production (generate with: openssl rand -hex 32)
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=1h

# Database: Using SQLite (no additional configuration needed)
